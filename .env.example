# Database Configuration
POSTGRES_DB=portfolio
POSTGRES_USER=user
POSTGRES_PASSWORD=your_secure_password_here
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# App Configuration
NODE_ENV=development
BACKEND_PORT=5000
FRONTEND_URL=http://localhost:3000

# Security
# Generate secure keys with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_at_least_64_chars_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_at_least_64_chars_long
ADMIN_PASSWORD=your_admin_password_here

# External Services (Optional)
SENTRY_DSN=
CLOUDINARY_URL=
RESEND_API_KEY=
OPENROUTER_API_KEY=
