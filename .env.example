# Database Configuration
POSTGRES_DB=portfolio
POSTGRES_USER=app_user
POSTGRES_PASSWORD=your_secure_password_here
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# App Configuration
NODE_ENV=development
BACKEND_PORT=5000
FRONTEND_URL=http://localhost:3000

# DO NOT USE THESE PLACEHOLDERS IN PRODUCTION — generate and store strong secrets securely (>=64 chars)
JWT_SECRET=GENERATE_SECURE_RANDOM_64+_CHAR_SECRET
JWT_REFRESH_SECRET=GENERATE_SECURE_RANDOM_64+_CHAR_SECRET
ADMIN_PASSWORD=your_admin_password_here

# External Services (Optional)
SENTRY_DSN=
CLOUDINARY_URL=
RESEND_API_KEY=
OPENROUTER_API_KEY=
