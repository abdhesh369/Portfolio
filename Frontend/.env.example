# Frontend Environment Variables
# Copy this file to .env and fill in the values.

# URL of the backend API (no trailing slash)
# - Development: leave empty — Vite will proxy requests to http://localhost:5000
# - Production: set to your deployed Render backend URL
VITE_API_URL=https://your-backend.onrender.com

# Cloudinary cloud name — required for OG image generation
# Found in: Cloudinary Dashboard → Settings → Account
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# Sentry error tracking (leave blank to disable)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
