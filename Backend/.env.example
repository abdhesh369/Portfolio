# ============================================
# BACKEND — ENVIRONMENT EXAMPLE
# ============================================

# ── Server ───────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_RENDER_URL=https://your-backend-url.onrender.com

# ── Database (PostgreSQL) ─────────────────────
DATABASE_URL=postgresql://user:password@host:port/database

# ── Authentication & Security ─────────────────
JWT_SECRET=generate_a_64_character_random_string_here
JWT_REFRESH_SECRET=generate_another_64_character_random_string_here
ADMIN_PASSWORD=your_secure_admin_password_here
ADMIN_EMAIL=admin@example.com

# ── Email (Resend) ───────────────────────────
RESEND_API_KEY=re_...
CONTACT_EMAIL=contact@example.com

# ── AI Services ──────────────────────────────
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-v1-...

# ── Cloudinary (Media) ────────────────────────
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ── Monitoring & Logging ──────────────────────
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── GitHub Integration ────────────────────────
GITHUB_USERNAME=your_username
GITHUB_TOKEN= # Optional: PAT for higher rate limits

# ── Background Services ───────────────────────
REDIS_URL=redis://localhost:6379 # Optional: Required for BullMQ
RENDER_DEPLOY_HOOK_URL= # Optional: Deploy trigger
