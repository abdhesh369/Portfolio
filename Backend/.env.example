# ============================================
# BACKEND — ENV TEMPLATE
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================

# ── Server ───────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── Database (Neon PostgreSQL) ───────────────
DATABASE_URL=postgresql://user:password@host:5432/portfolio

# ── Redis (required for refresh tokens, caching, queues) ──
REDIS_URL=redis://localhost:6379

# ── Authentication & Security (required) ─────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# JWT_SECRET is used for signing short-lived access tokens (15 min)
JWT_SECRET=your_jwt_secret_min_64_chars____________________________________________
# JWT_REFRESH_SECRET is reserved for signing refresh tokens (future use)
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_64_chars______________________________
ADMIN_PASSWORD=your_admin_password_here

# ── Email (Resend) ───────────────────────────
RESEND_API_KEY=your_resend_api_key_here
ADMIN_EMAIL=your-email@example.com
CONTACT_EMAIL=contact@yourdomain.com

# ── AI Chatbot ───────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Cloudinary (image uploads) ───────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Logging ──────────────────────────────────
# Valid levels: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# ── Sentry Error Tracking (optional) ─────────
# Leave blank to disable Sentry. Get DSN from https://sentry.io
SENTRY_DSN=
SENTRY_ENVIRONMENT=development