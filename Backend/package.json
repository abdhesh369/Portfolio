{
  "name": "portfolio-backend",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "env:validate": "node scripts/validate-env.js",
    "predev": "npm run env:validate",
    "dev": "tsx --watch src/index.ts",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "type-check": "tsc --noEmit",
    "build": "npm run build --prefix .. -w @portfolio/shared && tsc --project tsconfig.json",
    "prestart": "npm run env:validate",
    "start": "node --import ./dist/src/instrument.js ./dist/src/index.js",
    "migrate": "npx drizzle-kit migrate",
    "generate": "npx drizzle-kit generate",
    "db:backup": "cd scripts && ./backup-db.sh",
    "db:restore": "cd scripts && ./restore-db.sh",
    "db:test": "tsc --noEmit",
    "db:validate": "node scripts/validate-migrations.js",
    "db:status": "echo 'Check Neon Dashboard'",
    "db:reset": "npx tsx src/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@openrouter/sdk": "^0.9.11",
    "@portfolio/shared": "*",
    "@sentry/node": "^10.42.0",
    "@sentry/profiling-node": "^10.42.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "file-type": "^21.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "isomorphic-dompurify": "^2.36.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.12",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^7.0.4",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "supertest": "^7.2.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "fast-xml-parser": "^5.4.1",
    "esbuild": "^0.25.0",
    "ioredis": "5.10.0"
  },
  "engines": {
    "node": "22.x"
  }
}