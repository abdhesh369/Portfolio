{
    "name": "@portfolio/shared",
    "version": "2.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "development": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./schema": {
            "types": "./src/schema.ts",
            "development": "./src/schema.ts",
            "default": "./dist/schema.js"
        },
        "./routes": {
            "types": "./src/routes.ts",
            "development": "./src/routes.ts",
            "default": "./dist/routes.js"
        },
        "./utils": {
            "types": "./src/utils.ts",
            "development": "./src/utils.ts",
            "default": "./dist/utils.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc -w",
        "lint": "eslint src --ext .ts",
        "type-check": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "drizzle-zod": "^0.8.3",
        "zod": "^3.25.76",
        "drizzle-orm": "^0.45.1"
    },
    "devDependencies": {
        "typescript": "^5.7.3",
        "eslint": "^8.56.0",
        "rimraf": "^5.0.5"
    }
}